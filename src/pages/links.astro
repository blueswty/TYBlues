---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LINK_GROUPS } from "../data/links";
import { existsSync, readFileSync } from "node:fs";

const LOCAL_SVG_FALLBACK_MAP: Record<string, string> = {
  "www.szlcsc.com": "szlcsc.svg",
  "www.taobao.com": "taobao.svg",
  "www.jd.com": "jd.svg",
  "www.google.com": "google.svg",
  "www.wikipedia.org": "wikipedia.svg",
  "www.bilibili.com": "bilibili.svg",
  "www.youtube.com": "youtube.svg",
  "github.com": "github.svg",
  "gitee.com": "gitee.svg",
  "my.feishu.cn": "feishu.svg",
  "www.zhihu.com": "zhihu.svg",
  "smallpdf.com": "smallpdf.svg",
  "www.ti.com": "ti.svg",
  "www.st.com": "st.svg",
  "www.analog.com": "adi.svg",
  "www.espressif.com": "espressif.svg",
  "www.snapeda.com": "snapeda.svg",
  "oshwhub.com": "oshwhub.svg",
  "everycircuit.com": "everycircuit.svg",
  "www.tuv-lab.com": "tuv.svg",
  "www.aliyun.com": "aliyun.svg",
  "cloud.tencent.com": "tencent-cloud.svg",
  "www.cloudflare.com": "cloudflare.svg"
};

function getPublicAssetPath(fileName: string) {
  return `${import.meta.env.BASE_URL}site-icons/${fileName}`;
}

function hasPublicIcon(fileName: string) {
  const iconUrl = new URL(`../../public/site-icons/${fileName}`, import.meta.url);
  return existsSync(iconUrl);
}

function isRenderableImage(fileName: string) {
  const iconUrl = new URL(`../../public/site-icons/${fileName}`, import.meta.url);

  if (!existsSync(iconUrl)) {
    return false;
  }

  const bytes = readFileSync(iconUrl).subarray(0, 8);
  const header = Array.from(bytes);

  return (
    (header[0] === 0x00 && header[1] === 0x00 && (header[2] === 0x01 || header[2] === 0x02) && header[3] === 0x00) ||
    (header[0] === 0x89 && header[1] === 0x50 && header[2] === 0x4e && header[3] === 0x47) ||
    (header[0] === 0xff && header[1] === 0xd8 && header[2] === 0xff)
  );
}

function getLocalIcon(href: string) {
  try {
    const url = new URL(href);
    const icoFile = `${url.hostname}.ico`;

    if (isRenderableImage(icoFile)) {
      return getPublicAssetPath(icoFile);
    }

    const svgFile = LOCAL_SVG_FALLBACK_MAP[url.hostname];
    return svgFile && hasPublicIcon(svgFile) ? getPublicAssetPath(svgFile) : "";
  } catch {
    return "";
  }
}
---

<BaseLayout title="链接" description="常用网站链接">
  <div class="container">
    <header class="index-header single">
      <div>
        <p class="eyebrow">Links</p>
        <h1>链接</h1>
      </div>
    </header>

    <div class="link-groups">
      {LINK_GROUPS.map((group) => (
        <section class="link-group">
          <h2>{group.title}</h2>
          <div class="link-grid">
            {group.links.map((link) => {
              const localIcon = getLocalIcon(link.href);

              return (
                <a class="site-link" href={link.href} target="_blank" rel="noreferrer">
                  <span class:list={["site-icon", { "has-image": localIcon }]} aria-hidden="true">
                    <span class="site-icon-fallback">{link.name.slice(0, 1).toUpperCase()}</span>
                    {localIcon && (
                      <img src={localIcon} alt="" loading="lazy" decoding="async" />
                    )}
                  </span>
                  <span>{link.name}</span>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
