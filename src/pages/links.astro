---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LINK_GROUPS } from "../data/links";

const LOCAL_ICON_MAP: Record<string, string> = {
  "www.taobao.com": "/site-icons/www.taobao.com.ico",
  "www.jd.com": "/site-icons/www.jd.com.ico",
  "www.bilibili.com": "/site-icons/www.bilibili.com.ico",
  "github.com": "/site-icons/github.com.ico",
  "gitee.com": "/site-icons/gitee.com.ico",
  "my.feishu.cn": "/site-icons/my.feishu.cn.ico",
  "www.zhihu.com": "/site-icons/www.zhihu.com.ico",
  "smallpdf.com": "/site-icons/smallpdf.com.ico",
  "www.ti.com": "/site-icons/www.ti.com.ico",
  "www.st.com": "/site-icons/www.st.com.ico",
  "oshwhub.com": "/site-icons/oshwhub.com.ico",
  "www.aliyun.com": "/site-icons/www.aliyun.com.ico",
  "cloud.tencent.com": "/site-icons/cloud.tencent.com.ico",
  "www.cloudflare.com": "/site-icons/www.cloudflare.com.ico"
};

function getFaviconCandidates(href: string) {
  try {
    const url = new URL(href);
    const domain = url.hostname;
    const localIcon = LOCAL_ICON_MAP[domain];

    return [
      localIcon,
      `${url.origin}/favicon.ico`,
      `${url.origin}/apple-touch-icon.png`,
      `https://icons.duckduckgo.com/ip3/${domain}.ico`,
      `https://www.google.com/s2/favicons?domain=${domain}&sz=64`
    ].join("|");
  } catch {
    return "";
  }
}
---

<BaseLayout title="链接" description="常用网站链接">
  <div class="container">
    <header class="index-header single">
      <div>
        <p class="eyebrow">Links</p>
        <h1>链接</h1>
      </div>
    </header>

    <div class="link-groups">
      {LINK_GROUPS.map((group) => (
        <section class="link-group">
          <h2>{group.title}</h2>
          <div class="link-grid">
            {group.links.map((link) => (
              <a class="site-link" href={link.href} target="_blank" rel="noreferrer">
                <span class="site-icon" aria-hidden="true">
                  <span class="site-icon-fallback">{link.name.slice(0, 1).toUpperCase()}</span>
                  <img
                    src=""
                    alt=""
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                    data-favicon
                    data-favicon-sources={getFaviconCandidates(link.href)}
                  />
                </span>
                <span>{link.name}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <script is:inline>
    for (const icon of document.querySelectorAll("[data-favicon]")) {
      const wrapper = icon.closest(".site-icon");
      const sources = (icon.dataset.faviconSources ?? "").split("|").filter(Boolean);
      let index = 0;

      const tryNext = () => {
        if (index >= sources.length) {
          wrapper?.classList.remove("has-image");
          icon.hidden = true;
          return;
        }

        wrapper?.classList.remove("has-image");
        icon.hidden = true;
        icon.src = sources[index];
        index += 1;
      };

      icon.addEventListener("load", () => {
        icon.hidden = false;
        wrapper?.classList.add("has-image");
      });

      icon.addEventListener("error", () => {
        tryNext();
      });

      tryNext();
    }
  </script>
</BaseLayout>
