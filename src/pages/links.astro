---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LINK_GROUPS } from "../data/links";

function getDomain(href: string) {
  try {
    return new URL(href).hostname;
  } catch {
    return "";
  }
}

function getFaviconUrl(href: string) {
  const domain = getDomain(href);
  return domain ? `https://www.google.com/s2/favicons?domain=${domain}&sz=64` : "";
}
---

<BaseLayout title="链接" description="常用网站链接">
  <div class="container">
    <header class="index-header single">
      <div>
        <p class="eyebrow">Links</p>
        <h1>链接</h1>
      </div>
    </header>

    <div class="link-groups">
      {LINK_GROUPS.map((group) => (
        <section class="link-group">
          <h2>{group.title}</h2>
          <div class="link-grid">
            {group.links.map((link) => (
              <a class="site-link" href={link.href} target="_blank" rel="noreferrer">
                <span class="site-icon" aria-hidden="true">
                  <span class="site-icon-fallback">{link.name.slice(0, 1).toUpperCase()}</span>
                  <img src={getFaviconUrl(link.href)} alt="" loading="lazy" data-favicon />
                </span>
                <span>{link.name}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <script is:inline>
    for (const icon of document.querySelectorAll("[data-favicon]")) {
      icon.addEventListener("error", () => {
        icon.hidden = true;
      });
    }
  </script>
</BaseLayout>
