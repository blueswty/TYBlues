---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentCard from "../../components/ContentCard.astro";
import { weeklyPermalink } from "../../utils/content";

const issues = (await getCollection("weekly", ({ data }) => !data.draft))
  .sort((a, b) => b.data.issue - a.data.issue);
---

<BaseLayout title="周刊" description="周刊列表">
  <div class="container">
    <header class="index-header single">
      <div>
        <p class="eyebrow">Weekly</p>
        <h1>把一周的输入，整理成输出。</h1>
      </div>
    </header>
    <div class="timeline">
      {issues.map((issue) => (
        <ContentCard
          href={weeklyPermalink(issue.id)}
          title={issue.data.title}
          description={issue.data.description}
          meta={[`Issue ${issue.data.issue}`, issue.data.pubDate.toLocaleDateString("zh-CN")]}
          tags={issue.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>
