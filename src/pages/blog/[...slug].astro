---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { entrySlug, sortFeaturedFirst } from "../../utils/content";

export async function getStaticPaths() {
  const posts = sortFeaturedFirst(await getCollection("blog", ({ data }) => !data.draft));
  return posts.map((post) => ({
    params: { slug: entrySlug(post.id) },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <div class="post-layout">
    {tocHeadings.length > 0 && (
      <aside class="post-toc">
        <p class="post-toc-title">On This Page</p>
        <a class="post-toc-page-title" href="#article-top">{post.data.title}</a>
        <nav aria-label="Table of contents">
          {tocHeadings.map((heading) => (
            <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
              {heading.text}
            </a>
          ))}
        </nav>
      </aside>
    )}
    <article class="post-shell" id="article-top">
      <p class="eyebrow">Blog Post</p>
      <h1>{post.data.title}</h1>
      <div class="meta">
        <span>{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
        {post.data.updatedDate && <span>Updated {post.data.updatedDate.toLocaleDateString("zh-CN")}</span>}
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-row">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <div class="post-body">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
