---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentCard from "../components/ContentCard.astro";
import GalleryCard from "../components/GalleryCard.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { blogPermalink, galleryPermalink, sortFeaturedFirst, weeklyPermalink } from "../utils/content";

const blogPosts = sortFeaturedFirst(await getCollection("blog", ({ data }) => !data.draft)).slice(0, 2);

const weeklyPosts = (await getCollection("weekly", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 1);

const galleryItems = (await getCollection("gallery", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 1);

const latestWeekly = weeklyPosts[0];
const latestGallery = galleryItems[0];
---

<BaseLayout title={`${SITE_TITLE} | Home`} description={SITE_DESCRIPTION}>
  <div class="container home-shell">
    <section class="home-hero">
      <div class="home-hero-main">
        <span class="eyebrow">Independent maker / writer / observer</span>
        <h1>把零散的写作、照片和每周记录，慢慢收拢成一个长期更新的个人据点。</h1>
        <p class="home-lead">
          这里不追求像门户那样塞满入口，而是保留一条更清晰的阅读路径：长文沉淀想法，周刊整理输入，
          相册留下生活的光感与停顿。
        </p>
        <div class="hero-actions">
          <a class="button" href="/blog">进入日志</a>
          <a class="button-secondary" href="/about">了解我</a>
        </div>
      </div>

      <aside class="home-hero-side">
        <div class="home-note">
          <p class="home-note-label">Now</p>
          <p class="home-note-body">
            正在把这个站点整理成一个更轻、更稳的内容归档：少一点噪音，多一点持续更新的秩序。
          </p>
        </div>
        <div class="home-note">
          <p class="home-note-label">Workflow</p>
          <p class="home-note-body">
            Markdown 写作，Git 管理内容，Astro 生成静态页面。整个结构尽量简单，方便长期维护。
          </p>
        </div>
        <div class="home-status-row" aria-label="Site sections">
          <span class="status-pill">日志</span>
          <span class="status-pill">周刊</span>
          <span class="status-pill">相册</span>
          <span class="status-pill">RSS</span>
        </div>
      </aside>
    </section>

    <section class="section">
      <div class="section-heading">
        <div>
          <h2>Browse by Format</h2>
          <p>首页只保留三个明确入口，每一种内容都有不同的阅读节奏。</p>
        </div>
      </div>
      <div class="home-strip">
        <a class="strip-card" href="/blog">
          <span class="strip-kicker">Journal</span>
          <strong>日志</strong>
          <span>更完整的文章、笔记和技术沉淀，适合系统阅读。</span>
        </a>
        <a class="strip-card" href="/weekly">
          <span class="strip-kicker">Weekly</span>
          <strong>周刊</strong>
          <span>把一周的输入、判断和链接整理成轻量更新。</span>
        </a>
        <a class="strip-card" href="/gallery">
          <span class="strip-kicker">Gallery</span>
          <strong>相册</strong>
          <span>留给照片、城市和生活碎片的一个安静入口。</span>
        </a>
      </div>
    </section>

    <section class="section home-focus">
      <div class="section-heading">
        <div>
          <h2>Selected Updates</h2>
          <p>只展示最近最值得先看的内容，不再把所有栏目都在首页展开一遍。</p>
        </div>
      </div>
      <div class="home-stack">
        <div class="home-column home-column-wide">
          <div class="grid cols-1">
            {blogPosts.map((post) => (
              <ContentCard
                href={blogPermalink(post.id)}
                title={post.data.title}
                description={post.data.description}
                meta={[post.data.pubDate.toLocaleDateString("zh-CN")]}
                tags={post.data.tags}
                featured={post.data.featured}
              />
            ))}
          </div>
        </div>

        <div class="home-column">
          <div class="stack-cards">
            <a class="feature-panel" href={latestWeekly ? weeklyPermalink(latestWeekly.id) : "/weekly"}>
              <span class="strip-kicker">Latest Weekly</span>
              <h3>{latestWeekly?.data.title ?? "周刊内容即将更新"}</h3>
              <p>
                {latestWeekly?.data.description ??
                  "每周整理一次近期输入和判断，作为站点最轻量的更新形式。"}
              </p>
            </a>

            {latestGallery && (
              <GalleryCard
                title={latestGallery.data.title}
                description={latestGallery.data.description}
                cover={latestGallery.data.cover}
                href={galleryPermalink(latestGallery.id)}
                location={latestGallery.data.location}
                tags={latestGallery.data.tags}
                imageCount={latestGallery.data.images.length}
              />
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="home-summary">
        <a class="strip-card" href="/about">
          <span class="strip-kicker">About</span>
          <strong>关于这个站点</strong>
          <span>一个会持续更新的个人说明书，记录我在做什么、关心什么、想把它写成什么样。</span>
        </a>
        <div class="home-summary-copy">
          <span class="strip-kicker">Current Focus</span>
          <strong>先把主页做轻，再让内容自然长出来。</strong>
          <p>
            现在的首页更像一个入口页，而不是内容超市。后续随着文章、周刊和相册积累，再慢慢扩展二级页的丰富度。
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
