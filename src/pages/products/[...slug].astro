---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { entrySlug, getProductDescription, sortByPubDateDesc } from "../../utils/content";

export async function getStaticPaths() {
  const products = sortByPubDateDesc(await getCollection("products"));
  return products.map((product) => ({
    params: { slug: entrySlug(product.id) },
    props: { product }
  }));
}

const { product } = Astro.props;
const { Content, headings } = await render(product);
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const productDescription = getProductDescription(product);
---

<BaseLayout title={`${product.data.title} | 一拍即合`} description={productDescription}>
  <div class="post-layout">
    {tocHeadings.length > 0 && (
      <aside class="post-toc">
        <p class="post-toc-title">On This Page</p>
        <a class="post-toc-page-title" href="#article-top">{product.data.title}</a>
        <nav aria-label="Table of contents">
          {tocHeadings.map((heading) => (
            <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
              {heading.text}
            </a>
          ))}
        </nav>
      </aside>
    )}
    <article class="post-shell" id="article-top">
      <p class="eyebrow">Product</p>
      <h1>{product.data.title}</h1>
      {product.data.tags.length > 0 && (
        <div class="tag-row">
          {product.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <div class="product-hero-image">
        <img src={product.data.cover} alt={product.data.title} />
      </div>
      <p class="page-intro">{productDescription}</p>
      <div class="post-body">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
