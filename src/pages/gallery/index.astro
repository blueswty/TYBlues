---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import { galleryPermalink } from "../../utils/content";

const galleryItems = (await getCollection("gallery", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="相册" description="相册与影像入口">
  <div class="container">
    <header class="index-header single">
      <div>
        <p class="eyebrow">Gallery</p>
        <h1>时间里的取景框。</h1>
      </div>
    </header>
    <div class="grid cols-3">
      {galleryItems.map((item) => (
        <GalleryCard
          title={item.data.title}
          description={item.data.description}
          cover={item.data.cover}
          href={galleryPermalink(item.id)}
          location={item.data.location}
          tags={item.data.tags}
          imageCount={item.data.images.length}
        />
      ))}
    </div>
  </div>
</BaseLayout>
