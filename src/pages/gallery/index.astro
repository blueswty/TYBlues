---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import { galleryPermalink } from "../../utils/content";

const galleryItems = (await getCollection("gallery", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Gallery" description="相册与影像入口">
  <div class="container">
    <header class="page-header">
      <span class="eyebrow">Gallery</span>
      <h1 class="page-title">时空弧光。</h1>
      <p class="page-intro">
        当下瞬间可能是未来阴天里的一道光，把握现在、雕刻现在。
      </p>
    </header>
    <div class="grid cols-3">
      {galleryItems.map((item) => (
        <GalleryCard
          title={item.data.title}
          description={item.data.description}
          cover={item.data.cover}
          href={galleryPermalink(item.id)}
          location={item.data.location}
          tags={item.data.tags}
          imageCount={item.data.images.length}
        />
      ))}
    </div>
  </div>
</BaseLayout>
