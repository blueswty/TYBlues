---
interface Props {
  title: string;
  description?: string;
  actionHref?: string;
  actionLabel?: string;
}

const { title, description, actionHref, actionLabel } = Astro.props;
---

<div class="section-heading">
  <div>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>
  {actionHref && actionLabel && <a class="button-secondary" href={actionHref}>{actionLabel}</a>}
</div>
