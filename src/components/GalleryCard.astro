---
interface Props {
  title: string;
  description: string;
  cover: string;
  href: string;
  location?: string;
  tags?: string[];
  imageCount?: number;
}

const { title, description, cover, href, location, tags = [], imageCount = 0 } = Astro.props;
---

<article class="content-card">
  <div class="gallery-cover">
    <a href={href}>
      <img src={cover} alt={title} loading="lazy" />
    </a>
  </div>
  <h3>
    <a href={href}>{title}</a>
  </h3>
  <p class="muted">{description}</p>
  <p class="meta">
    {location && <span>{location}</span>}
    {imageCount > 0 && <span>{imageCount} photos</span>}
  </p>
  {tags.length > 0 && (
    <div class="tag-row">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>
