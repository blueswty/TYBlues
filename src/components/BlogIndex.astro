---
import type { CollectionEntry } from "astro:content";
import { blogPermalink } from "../utils/content";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
const tagCounts = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((left, right) => {
  if (right[1] !== left[1]) return right[1] - left[1];
  return left[0].localeCompare(right[0], "zh-CN");
});
---

<section class="content-index" data-filter-scope>
  <aside class="filter-panel" aria-label="博客筛选">
    <div class="filter-panel-head">
      <p class="panel-label">标签</p>
      <button class="text-button" type="button" data-clear-filter>清除</button>
    </div>
    <label class="filter-search">
      <span>搜索</span>
      <input type="search" placeholder="标题、简介、标签" data-filter-search />
    </label>
    <div class="tag-filter-list">
      {tags.map(([tag, count]) => (
        <button class="tag-filter" type="button" data-tag-button data-tag={tag} aria-pressed="false">
          <span>{tag}</span>
          <strong>{count}</strong>
        </button>
      ))}
    </div>
  </aside>

  <div class="content-results">
    <header class="index-header">
      <div>
        <p class="eyebrow">Blog</p>
        <h1>博客</h1>
      </div>
      <p class="result-count" data-result-count>{posts.length} 篇文章</p>
    </header>

    <div class="entry-list">
      {posts.map((post) => (
        <article
          class="blog-list-item"
          data-filter-item
          data-tags={post.data.tags.join("|").toLowerCase()}
          data-title={post.data.title.toLowerCase()}
          data-description={post.data.description.toLowerCase()}
        >
          <div class="entry-date">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("zh-CN")}</time>
          </div>
          <div class="entry-main">
            <h2><a href={blogPermalink(post.id)}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-row compact">
                {post.data.tags.map((tag) => (
                  <button class="tag" type="button" data-inline-tag={tag}>{tag}</button>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

    <p class="empty-state" data-empty-state hidden>没有找到匹配的文章。</p>
  </div>
</section>

<script is:inline>
  (() => {
    const scopes = document.querySelectorAll("[data-filter-scope]");

    for (const scope of scopes) {
      const search = scope.querySelector("[data-filter-search]");
      const clear = scope.querySelector("[data-clear-filter]");
      const buttons = Array.from(scope.querySelectorAll("[data-tag-button]"));
      const inlineTags = Array.from(scope.querySelectorAll("[data-inline-tag]"));
      const items = Array.from(scope.querySelectorAll("[data-filter-item]"));
      const count = scope.querySelector("[data-result-count]");
      const empty = scope.querySelector("[data-empty-state]");
      let activeTag = "";

      const applyFilter = () => {
        const query =
          search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : "";
        let visible = 0;

        for (const item of items) {
          const itemTags = (item.getAttribute("data-tags") ?? "").split("|").filter(Boolean);
          const title = (item.getAttribute("data-title") ?? "").toLowerCase();
          const description = (item.getAttribute("data-description") ?? "").toLowerCase();
          const matchesTag = !activeTag || itemTags.includes(activeTag.toLowerCase());
          const matchesQuery =
            !query ||
            title.includes(query) ||
            description.includes(query) ||
            itemTags.some((tag) => tag.includes(query));
          const shouldShow = matchesTag && matchesQuery;

          if (shouldShow) {
            item.removeAttribute("hidden");
            visible += 1;
          } else {
            item.setAttribute("hidden", "");
          }
        }

        for (const button of buttons) {
          const tagValue = button.getAttribute("data-tag") ?? "";
          button.setAttribute("aria-pressed", tagValue === activeTag ? "true" : "false");
        }

        if (count) count.textContent = `${visible} 篇文章`;
        if (empty) {
          if (visible === 0) {
            empty.removeAttribute("hidden");
          } else {
            empty.setAttribute("hidden", "");
          }
        }
      };

      for (const button of buttons) {
        button.addEventListener("click", () => {
          const nextTag = button.getAttribute("data-tag") ?? "";
          activeTag = activeTag === nextTag ? "" : nextTag;
          applyFilter();
        });
      }

      for (const tag of inlineTags) {
        tag.addEventListener("click", () => {
          activeTag = tag.getAttribute("data-inline-tag") ?? "";
          applyFilter();
        });
      }

      if (search instanceof HTMLInputElement) {
        search.addEventListener("input", applyFilter);
      }

      clear?.addEventListener("click", () => {
        activeTag = "";
        if (search instanceof HTMLInputElement) search.value = "";
        applyFilter();
      });

      applyFilter();
    }
  })();
</script>
