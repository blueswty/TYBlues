---
import "../styles/global.css";
import "katex/dist/katex.min.css";
import { NAV_ITEMS, SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  pathname = Astro.url.pathname
} = Astro.props;

function isActiveNavItem(href: string) {
  if (href === "/") {
    return pathname === "/" || pathname === "/blog" || pathname.startsWith("/blog/");
  }

  if (href === "/tools/data/crc-checksum") {
    return pathname === "/tools" || pathname.startsWith("/tools/");
  }

  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href="/">{SITE_TITLE}</a>
        <nav class="nav" aria-label="Main navigation">
          {NAV_ITEMS.map((item) => (
            <a href={item.href} aria-current={isActiveNavItem(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="site-shell">
      <slot />
    </main>
    <footer class="container site-footer">
      <div class="site-footer-main">
        <div class="site-footer-copy">
          <p class="site-footer-title">{SITE_TITLE}</p>
          <p>记录想法、整理经验，也欢迎交流合作与问题反馈。</p>
        </div>
        <div class="site-footer-links" aria-label="Footer links">
          <a class="site-footer-link is-email" href="mailto:bluestywang@gmail.com">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m4 7 8 6 8-6"></path>
            </svg>
            联系我
          </a>
          <a class="site-footer-link" href="/links">常用链接</a>
          <a class="site-footer-link" href="/rss.xml">RSS 地址</a>
        </div>
      </div>
    </footer>
    <button class="back-to-top" type="button" aria-label="回到顶部" title="回到顶部">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <path d="m18 15-6-6-6 6"></path>
      </svg>
    </button>
    <script is:inline>
      const siteHeader = document.querySelector(".site-header");
      const backToTop = document.querySelector(".back-to-top");
      let lastScrollY = window.scrollY;
      let ticking = false;

      const updateHeaderVisibility = () => {
        const currentScrollY = window.scrollY;
        const scrollingDown = currentScrollY > lastScrollY;

        siteHeader?.classList.toggle("is-hidden", scrollingDown && currentScrollY > 80);
        backToTop?.classList.toggle("is-visible", currentScrollY > 420);
        lastScrollY = Math.max(currentScrollY, 0);
        ticking = false;
      };

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(updateHeaderVisibility);
            ticking = true;
          }
        },
        { passive: true }
      );

      backToTop?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      const codeBlocks = document.querySelectorAll(".post-body pre");

      for (const block of codeBlocks) {
        if (block.querySelector(".code-copy-button")) continue;

        const code = block.querySelector("code");
        if (!code) continue;

        const languageClass = [...code.classList].find((className) => className.startsWith("language-"));
        if (languageClass) {
          block.dataset.language = languageClass.replace("language-", "");
        }

        const button = document.createElement("button");
        button.type = "button";
        button.className = "code-copy-button";
        button.textContent = "Copy";

        button.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(code.textContent ?? "");
            button.textContent = "Copied";
            button.classList.add("is-copied");

            window.setTimeout(() => {
              button.textContent = "Copy";
              button.classList.remove("is-copied");
            }, 1400);
          } catch {
            button.textContent = "Failed";

            window.setTimeout(() => {
              button.textContent = "Copy";
            }, 1400);
          }
        });

        block.append(button);
      }

      const tocLinks = [...document.querySelectorAll(".post-toc a")];
      const headings = tocLinks
        .map((link) => {
          const href = link.getAttribute("href");
          if (!href?.startsWith("#")) return null;

          const heading = document.getElementById(href.slice(1));
          if (!heading) return null;

          return { link, heading };
        })
        .filter(Boolean);

      if (headings.length > 0) {
        const setActive = (activeId) => {
          for (const item of headings) {
            item.link.classList.toggle("is-active", item.heading.id === activeId);
          }
        };

        const observer = new IntersectionObserver(
          (entries) => {
            const visibleEntries = entries
              .filter((entry) => entry.isIntersecting)
              .sort((left, right) => right.intersectionRatio - left.intersectionRatio);

            if (visibleEntries.length > 0) {
              setActive(visibleEntries[0].target.id);
            }
          },
          {
            rootMargin: "-96px 0px -60% 0px",
            threshold: [0, 0.2, 0.6, 1]
          }
        );

        for (const item of headings) {
          observer.observe(item.heading);
        }

        setActive(headings[0].heading.id);
      }
    </script>
  </body>
</html>
